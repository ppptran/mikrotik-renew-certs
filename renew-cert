:local domainName "your.subdomain.com";
:local fwComment "allow Let's Encrypt";
:local renewThreshold 10d;

# Default certificate name generated by MikroTik ACME
:local targetCertName ("acme_cert_" . $domainName);

# ===== CHECK CERTIFICATE =====
:local needRenew false;
:local currentExpiry "unknown";

# Find the specific certificate by its strict name
:local certs [/certificate find where name=$targetCertName];

:if ([:len $certs] = 0) do={
    :log warning "LE SCRIPT: Certificate not found in storage. Forcing initial ACME run.";
    :set needRenew true;
} else={
    # Directly read the expiry time of the existing certificate
    :set currentExpiry [/certificate get [find name=$targetCertName] expires-after];
    
    # Compare with the 10-day threshold using MikroTik's native Interval data type
    :if ($currentExpiry < $renewThreshold) do={
        :set needRenew true;
    }
}

# If the certificate is still valid, completely stop the script here
:if ($needRenew = false) do={
    # ADDED: Print the exact remaining time (e.g., 12w4d...) into the system log
    :log info ("LE SCRIPT: Certificate [" . $domainName . "] is still valid (" . [:tostr $currentExpiry] . " left). Renewal skipped.");
    :return true;
}

:log warning ("LE SCRIPT: Certificate [" . $domainName . "] is expiring soon (" . [:tostr $currentExpiry] . " left) or missing. Starting renewal process...");

# ===== RENEW CERTIFICATE =====

# Temporarily enable firewall rules and WWW service for Let's Encrypt validation
/ipv6 firewall filter enable [find where comment=$fwComment];
# /ip firewall filter enable [find where comment=$fwComment];
/ip service enable [find name="www" !dynamic];

# FIX: Remove the old certificate first to completely prevent "name must be unique" error
:if ([/certificate find where name=$targetCertName] != "") do={
    /certificate remove [find where name=$targetCertName];
    :log info "LE SCRIPT: Old certificate removed to clear the namespace.";
}

# Execute the exact ACME command supported by your MikroTik x86
/certificate add-acme domain-names=$domainName;

# Immediately disable services and firewall rules right after hitting the API
/ip service disable [find name="www" !dynamic];
# /ip firewall filter disable [find where comment=$fwComment];
/ipv6 firewall filter disable [find where comment=$fwComment];

# Wait 30 seconds for the background ACME challenge process to fetch the new cert
:log info "LE SCRIPT: Waiting 30s for ACME challenge process to complete...";
:delay 30s;

# ===== UPDATE SERVICES WITH NEW CERTIFICATE =====

# Check if the new certificate has been successfully downloaded
:if ([:len [/certificate find where name=$targetCertName]] > 0) do={
    :log info ("LE SCRIPT: Successfully generated new certificate: " . $targetCertName . ". Syncing services...");
    
    # Update certificate for WWW-SSL service
    #/ip service set [find name="www-ssl" !dynamic] certificate=$targetCertName;
    
    # Update certificate for Hotspot Profile
    /ip hotspot profile set [find dns-name=$domainName] ssl-certificate=none;
    /ip hotspot profile set [find dns-name=$domainName] ssl-certificate=$targetCertName;
    
    :log warning "LE SCRIPT: Renewal and service sync successfully completed!";
} else {
    :log error "LE SCRIPT: Renewal failed or the ACME process took longer than 30s!";
}
